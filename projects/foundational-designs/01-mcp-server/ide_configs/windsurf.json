{
  "_comment": [
    "Windsurf (Codeium) MCP server configuration.",
    "Config file location:",
    "  ~/.codeium/windsurf/mcp_config.json",
    "See: https://docs.windsurf.com/windsurf/mcp"
  ],
  "mcpServers": {
    "acme-platform": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "RAILS_API_TOKEN", "acme-mcp:latest"],
      "env": {
        "RAILS_API_TOKEN": "your-token-here"
      }
    },
    "acme-platform-local": {
      "_comment": "Alternative: run directly with Python (no Docker). Requires uv sync first.",
      "command": "python",
      "args": ["server_from_spec.py"],
      "cwd": "/path/to/01-mcp-server",
      "env": {
        "RAILS_API_TOKEN": "your-token-here"
      }
    }
  }
}
